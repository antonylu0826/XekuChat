# ============================================================
# XekuChat Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=xekuchat
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=xekuchat
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- MinIO (S3-compatible file storage) ----
MINIO_ROOT_USER=xekuchat
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=xekuchat-files
# Public URL for browser-accessible files (set to APP_URL/files when behind a proxy)
MINIO_PUBLIC_URL=

# ---- Keycloak ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_in_production
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak
KC_DB_USERNAME=${POSTGRES_USER}
KC_DB_PASSWORD=${POSTGRES_PASSWORD}

# ---- OIDC (Keycloak or any OIDC provider) ----
OIDC_ISSUER=http://keycloak:8080/realms/xekuchat
OIDC_CLIENT_ID=xekuchat
OIDC_CLIENT_SECRET=change_me_in_production
OIDC_REDIRECT_URI=https://chat.example.com/auth/callback

# ---- JWT ----
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ---- Tunnel / reverse proxy (optional, for cross-network dev testing) ----
# When exposing the app through a tunnel (e.g. ngrok, Cloudflare Tunnel),
# set these to the public URL then restart the bun server:
OIDC_PUBLIC_ISSUER=
APP_PUBLIC_URL=

# ---- Web Push (VAPID) ----
# Generate with: bunx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@example.com

# ---- App ----
APP_URL=https://chat.example.com
APP_PORT=3000
NODE_ENV=production
# Set to false to hide the Keycloak/OIDC login button on the login page (default: true)
OIDC_ENABLED=true

# ---- System Admin (built-in super admin, independent of OIDC) ----
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change_me_in_production

# ---- AI API Key Encryption ----
AI_ENCRYPTION_KEY=change_me_to_a_random_32_byte_hex_string
