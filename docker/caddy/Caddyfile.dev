# XekuChat — Dev Reverse Proxy
# Combines API server (3000) + Vite dev server (5173) into one entry point.
# Used by the zrok container for cross-network testing.
#
# Vite HMR websocket (/vite-hmr, /@vite/*) and app WS (/ws) are handled separately.

{
  admin off
  # Disable HTTPS — Caddy is behind zrok which provides TLS
}

:80 {
  # ── App WebSocket ──────────────────────────────────────────
  @appWs {
    path /ws
    header Connection *Upgrade*
    header Upgrade websocket
  }
  handle @appWs {
    reverse_proxy host.docker.internal:3000
  }

  # ── Vite HMR WebSocket ─────────────────────────────────────
  @viteWs {
    path /__vite_hmr /vite-hmr
    header Connection *Upgrade*
    header Upgrade websocket
  }
  handle @viteWs {
    reverse_proxy host.docker.internal:5173
  }

  # ── MinIO file storage ─────────────────────────────────────
  handle /files/* {
    uri replace /files/ /xekuchat-files/
    reverse_proxy minio:9000
  }

  # ── Backend routes ─────────────────────────────────────────
  handle /api/* {
    reverse_proxy host.docker.internal:3000
  }
  handle /auth/* {
    reverse_proxy host.docker.internal:3000
  }
  handle /health* {
    reverse_proxy host.docker.internal:3000
  }

  # ── Keycloak (proxied so external browsers can reach it) ───
  handle /realms/* {
    reverse_proxy keycloak:8080
  }
  handle /resources/* {
    reverse_proxy keycloak:8080
  }
  handle /js/* {
    reverse_proxy keycloak:8080
  }

  # ── Everything else → Vite ─────────────────────────────────
  handle {
    reverse_proxy host.docker.internal:5173 {
      # Pass original Host so Vite HMR works correctly
      header_up Host {upstream_hostport}
    }
  }
}
