generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Organization
// ============================================================

model Organization {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  members      OrgMember[]
  channels     Channel[]
  settings     OrgSettings?
  aiAssistants  AIAssistant[]
  aiSkills      AISkill[]
  mcpServers    MCPServer[]
  integrations  Integration[]

  createdAt DateTime @default(now())
}

model OrgSettings {
  id                String       @id @default(cuid())
  orgId             String       @unique
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messageRetainDays Int?         // null = keep forever
}

model OrgMember {
  id     String       @id @default(cuid())
  userId String
  orgId  String
  role   String       @default("member") // admin | member | guest
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

// ============================================================
// User
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatar    String?
  sub       String?  // OIDC subject identifier
  provider  String?  // keycloak | google | github | azure | oidc
  passwordHash String?  // For local auth (provider="local")
  isBot        Boolean  @default(false)
  isDisabled   Boolean  @default(false)
  isSuperAdmin Boolean  @default(false)
  status       String   @default("offline")
  createdAt DateTime @default(now())

  orgMemberships     OrgMember[]
  channelMemberships ChannelMember[]
  sentMessages       Message[]           @relation("sender")
  reactions          Reaction[]
  readCursors        ChannelReadCursor[]
  pushSubscriptions  PushSubscription[]
  aiAssistant        AIAssistant?
  integration        Integration?
}

// ============================================================
// Channel
// ============================================================

model Channel {
  id                  String               @id @default(cuid())
  name                String
  icon                String?              // emoji icon, e.g. "📢"
  type                String               @default("group") // group | dm | readonly
  isPrivate           Boolean              @default(false)
  orgId               String
  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members             ChannelMember[]
  messages            Message[]
  aiAssistantChannels  AIAssistantChannel[]
  integrationChannels  IntegrationChannel[]
  createdAt            DateTime             @default(now())

  @@index([orgId])
}

model ChannelMember {
  id        String  @id @default(cuid())
  userId    String
  channelId String
  role      String  @default("member") // admin | member
  isMuted   Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
}

// ============================================================
// Message
// ============================================================

model Message {
  id          String       @id @default(cuid())
  content     String
  type        String       @default("text") // text | image | file | system
  channelId   String
  senderId    String
  replyToId   String?
  isRetracted Boolean      @default(false)
  editedAt    DateTime?
  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender      User         @relation("sender", fields: [senderId], references: [id])
  replyTo     Message?     @relation("thread", fields: [replyToId], references: [id])
  replies     Message[]    @relation("thread")
  reactions   Reaction[]
  attachments Attachment[]
  createdAt   DateTime     @default(now())

  @@index([channelId, createdAt])
}

// ============================================================
// Read Cursor (watermark approach)
// ============================================================

model ChannelReadCursor {
  id            String   @id @default(cuid())
  userId        String
  channelId     String
  lastReadMsgId String
  lastReadAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId, lastReadMsgId])
}

// ============================================================
// Reaction / Attachment
// ============================================================

model Reaction {
  id        String  @id @default(cuid())
  emoji     String
  messageId String
  userId    String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Attachment {
  id        String  @id @default(cuid())
  name      String
  url       String
  mimeType  String
  size      Int
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ============================================================
// Audit Log
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  action    String
  actorId   String
  targetId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([actorId])
}

// ============================================================
// AI Assistant
// ============================================================

model AIAssistant {
  id           String                 @id @default(cuid())
  orgId        String
  org          Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  avatar       String?
  provider     String                 @default("openai") // openai | anthropic
  systemPrompt String
  baseUrl      String
  apiKeyEnc    String                 // AES-256-GCM encrypted
  model        String
  maxContext   Int                    @default(20)
  isActive     Boolean                @default(true)
  botUserId    String                 @unique
  botUser      User                   @relation(fields: [botUserId], references: [id])
  channels     AIAssistantChannel[]
  skills       AIAssistantSkill[]
  mcpServers   AIAssistantMCPServer[]
  usageLogs    AIUsageLog[]
  createdAt    DateTime               @default(now())

  @@index([orgId])
}

model AIAssistantChannel {
  id          String      @id @default(cuid())
  assistantId String
  channelId   String
  assistant   AIAssistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  channel     Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([assistantId, channelId])
}

// ---- AI Skills (Part A + B) ----

model AISkill {
  id          String             @id @default(cuid())
  orgId       String
  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String             // unique display name
  description String
  type        String             // "builtin" | "webhook"
  builtinName String?            // builtin type: "web_search" | "fetch_url" | "current_datetime" | "calculator"
  method      String?            // webhook type: "GET" | "POST"
  endpoint    String?            // webhook type: URL
  headers     Json?              // webhook type: {"Authorization": "..."}
  paramSchema Json?              // JSON Schema object for parameters
  isActive    Boolean            @default(true)
  assistants  AIAssistantSkill[]
  createdAt   DateTime           @default(now())

  @@index([orgId])
}

model AIAssistantSkill {
  assistantId String
  skillId     String
  assistant   AIAssistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  skill       AISkill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([assistantId, skillId])
}

// ---- MCP Servers (Part D) ----

model MCPServer {
  id          String                 @id @default(cuid())
  orgId       String
  org         Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  transport   String                 // "stdio" | "sse"
  command     String?                // stdio: e.g. "npx @modelcontextprotocol/server-filesystem /path"
  url         String?                // sse: e.g. "http://localhost:3001"
  envVars     Json?                  // {"KEY": "value"}
  isActive    Boolean                @default(true)
  assistants  AIAssistantMCPServer[]
  createdAt   DateTime               @default(now())

  @@index([orgId])
}

model AIAssistantMCPServer {
  assistantId  String
  mcpServerId  String
  assistant    AIAssistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  mcpServer    MCPServer   @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@id([assistantId, mcpServerId])
}

// ---- AI Usage Log (Part E) ----

model AIUsageLog {
  id               String      @id @default(cuid())
  assistantId      String
  assistant        AIAssistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  channelId        String
  messageId        String?
  provider         String
  model            String
  promptTokens     Int         @default(0)
  completionTokens Int         @default(0)
  costUsd          Float       @default(0)
  ttftMs           Int?        // time-to-first-token ms
  totalMs          Int         @default(0)
  toolCallCount    Int         @default(0)
  error            String?
  createdAt        DateTime    @default(now())

  @@index([assistantId])
  @@index([createdAt])
}

// ============================================================
// Integration API (Phase 8)
// ============================================================

model Integration {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  apiKeyHash    String   @unique   // SHA-256, verification only
  apiKeyPrefix  String             // "xk_live_a3f8..." for UI display
  webhookUrl    String?            // event callback URL
  webhookSecret String?            // HMAC-SHA256 signing key
  rateLimit     Int      @default(60) // requests per minute
  isActive      Boolean  @default(true)
  botUserId     String   @unique
  botUser       User     @relation(fields: [botUserId], references: [id])
  channels      IntegrationChannel[]
  auditLogs     IntegrationAuditLog[]
  webhookDeliveries WebhookDelivery[]
  createdAt     DateTime @default(now())

  @@index([orgId])
}

model IntegrationChannel {
  id            String      @id @default(cuid())
  integrationId String
  channelId     String
  permissions   String[]    // ["send", "read", "webhook"]
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  channel       Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([integrationId, channelId])
}

model IntegrationAuditLog {
  id            String      @id @default(cuid())
  integrationId String
  endpoint      String
  method        String
  statusCode    Int
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([integrationId, createdAt])
}

model WebhookDelivery {
  id            String      @id @default(cuid())
  integrationId String
  event         String      // "message.created", "message.mention"
  payload       Json
  status        String      @default("pending") // pending | success | failed
  attempts      Int         @default(0)
  lastAttemptAt DateTime?
  responseCode  Int?
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([integrationId, createdAt])
  @@index([status])
}

// ============================================================
// Push Subscription
// ============================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      Json     // { p256dh, auth }
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}
