{
  "name": "@xekuchat/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file ../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "db:generate": "bunx prisma generate",
    "db:push": "bun --env-file ../../.env scripts/prisma.ts db push",
    "db:migrate": "bun --env-file ../../.env scripts/prisma.ts migrate dev",
    "db:studio": "bun --env-file ../../.env scripts/prisma.ts studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xekuchat/core": "workspace:*",
    "hono": "^4",
    "@prisma/client": "^6",
    "ioredis": "^5",
    "jose": "^6",
    "web-push": "^3",
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/web-push": "^3",
    "prisma": "^6",
    "typescript": "^5"
  }
}
