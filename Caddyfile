{$APP_DOMAIN:chat.example.com} {
	# API and WebSocket — sticky session via cookie for WebSocket
	@ws {
		path /ws/*
	}
	reverse_proxy @ws app1:3000 app2:3000 {
		lb_policy cookie
		health_uri /health
		health_interval 10s
	}

	# API routes
	@api {
		path /api/*
		path /auth/*
	}
	reverse_proxy @api app1:3000 app2:3000 {
		lb_policy round_robin
		health_uri /health
		health_interval 10s
	}

	# Static files (SPA)
	reverse_proxy app1:3000 app2:3000 {
		lb_policy round_robin
	}

	# Security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
